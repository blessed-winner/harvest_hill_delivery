# =============================================================
# Frontend Environment Variables — EXAMPLE / TEMPLATE
# =============================================================
# Copy this file to .env.local for local development.
# On Vercel / Railway / Render, set these in the dashboard.

# ── Backend API ──────────────────────────────────────────────
# HTTP base URL for REST API calls (no trailing slash)
NEXT_PUBLIC_API_URL=https://your-backend-domain.com

# WebSocket base URL for real-time notifications (no trailing slash)
NEXT_PUBLIC_WS_URL=wss://your-backend-domain.com
